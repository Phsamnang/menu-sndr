generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  displayName String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  menuItems   MenuItem[]

  @@index([name])
  @@index([sortOrder])
  @@index([isActive])
}

model TableType {
  id          String    @id @default(cuid())
  name        String    @unique
  displayName String
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  prices      Price[]
  tables      Table[]

  @@index([name])
  @@index([order])
}

model Table {
  id          String        @id @default(cuid())
  number      String        @unique
  name        String?
  capacity    Int           @default(4)
  tableTypeId String
  tableType   TableType     @relation(fields: [tableTypeId], references: [id], onDelete: Restrict)
  status      String        @default("available") // available, occupied, reserved, maintenance
  floor       String?       // ground, first, outdoor, etc.
  section     String?       // smoking, non-smoking, vip, etc.
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  orders      Order[]
  reservations Reservation[]

  @@index([tableTypeId])
  @@index([number])
  @@index([status])
  @@index([floor])
}

model MenuItem {
  id              String      @id @default(cuid())
  name            String
  description     String
  image           String
  categoryId      String
  category        Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  isCook          Boolean     @default(false)
  isAvailable     Boolean     @default(true)
  preparationTime Int?        // in minutes
  allergens       String?     // JSON array: ["nuts", "dairy", "gluten"]
  isPopular       Boolean     @default(false)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  createdBy       String?
  updatedBy       String?
  prices          Price[]
  orderItems      OrderItem[]
  recipeItems     RecipeItem[]

  @@index([categoryId])
  @@index([isAvailable])
  @@index([sortOrder])
  @@index([isPopular])
}

model Price {
  id          String    @id @default(cuid())
  menuItemId  String
  tableTypeId String
  amount      Float
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  tableType   TableType @relation(fields: [tableTypeId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([menuItemId, tableTypeId])
  @@index([menuItemId])
  @@index([tableTypeId])
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique
  tableId        String?
  table          Table?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName   String?
  orderType      String      @default("dine_in") // dine_in, takeout, delivery
  status         String      @default("new") // new, on_process, ready, completed, cancelled
  subtotal       Float       @default(0)
  discountType   String?     // percentage, amount, coupon
  discountValue  Float?      @default(0)
  discountAmount Float       @default(0)
  taxRate        Float       @default(0)
  taxAmount      Float       @default(0)
  serviceCharge  Float       @default(0)
  total          Float       @default(0)
  grandTotal     Float       @default(0)
  paidAmount     Float       @default(0)
  changeAmount   Float       @default(0)
  paymentStatus  String      @default("unpaid") // unpaid, partial, paid, refunded
  paymentMethod  String?     // cash, card, transfer, etc.
  servedBy       String?     // waiter/server user ID
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  completedAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  createdBy      String?
  items          OrderItem[]
  payments       Payment[]
  statusHistory  OrderStatusHistory[]

  @@index([orderNumber])
  @@index([tableId])
  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderType])
  @@index([createdAt])
  @@index([servedBy])
}

model OrderItem {
  id            String         @id @default(cuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId    String
  menuItem      MenuItem       @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  quantity      Int            @default(1)
  unitPrice     Float
  totalPrice    Float
  status        String         @default("pending") // pending, preparing, ready, served, cancelled
  specialNotes  String?        // customer requests: no ice, extra spicy, etc.
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  kitchenOrder  KitchenOrder?

  @@index([orderId])
  @@index([menuItemId])
  @@index([status])
}

model Role {
  id             String              @id @default(cuid())
  name           String              @unique
  displayName    String
  description    String?
  permissions    String?             // JSON: ["orders.create", "menu.edit", etc.]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  users          User[]
  adminMenuItems AdminMenuItemRole[]

  @@index([name])
}

model User {
  id                String         @id @default(cuid())
  username          String         @unique
  password          String
  fullName          String?
  email             String?        @unique
  phone             String?
  roleId            String
  role              Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  isActive          Boolean        @default(true)
  lastLoginAt       DateTime?
  passwordChangedAt DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  shifts            Shift[]
  auditLogs         AuditLog[]

  @@index([username])
  @@index([email])
  @@index([roleId])
  @@index([isActive])
}

model AdminMenuItem {
  id          String              @id @default(cuid())
  href        String              @unique
  iconName    String
  title       String
  description String
  iconColor   String?
  order       Int                 @default(0)
  parentId    String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  roles       AdminMenuItemRole[]

  @@index([href])
  @@index([order])
  @@index([parentId])
}

model AdminMenuItemRole {
  id             String        @id @default(cuid())
  adminMenuItemId String
  roleId         String
  adminMenuItem  AdminMenuItem @relation(fields: [adminMenuItemId], references: [id], onDelete: Cascade)
  role           Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@unique([adminMenuItemId, roleId])
  @@index([adminMenuItemId])
  @@index([roleId])
}

model ShopInfo {
  id          String   @id @default(cuid())
  name        String
  nameKh      String?  // Khmer name
  address     String?
  addressKh   String?
  phone       String?
  email       String?
  website     String?
  logo        String?
  taxId       String?
  currency    String   @default("USD")
  timezone    String   @default("Asia/Phnom_Penh")
  dateFormat  String   @default("DD/MM/YYYY")
  timeFormat  String   @default("HH:mm")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id            String        @id @default(cuid())
  title         String
  description   String?
  amount        Float?        // Deprecated: Use amountUSD and amountKHR instead
  amountUSD     Float         @default(0)
  amountKHR     Float         @default(0)
  category      String
  subCategory   String?
  date          DateTime      @default(now())
  receiptNumber String?
  supplierId    String?
  supplier      Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  vendor        String?
  paymentMethod String?       // cash, bank_transfer, card, credit
  paymentStatus String        @default("unpaid") // paid, unpaid, partial
  receiptImage  String?
  notes         String?
  approvedBy    String?       // user ID
  currency      String?       // Deprecated: Items can have different currencies
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdBy     String?
  items         ExpenseItem[]

  @@index([category])
  @@index([subCategory])
  @@index([date])
  @@index([supplierId])
  @@index([vendor])
  @@index([paymentStatus])
}

model Unit {
  id            String          @id @default(cuid())
  name          String          @unique
  displayName   String
  symbol        String?         // kg, g, L, ml, pcs, etc.
  order         Int             @default(0)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  products      Product[]
  expenseItems  ExpenseItem[]
  inventories   Inventory[]
  stockMovements StockMovement[]

  @@index([name])
  @@index([order])
  @@index([isActive])
}

model Product {
  id             String          @id @default(cuid())
  name           String          @unique
  description    String?
  sku            String?         @unique
  unitId         String?
  unit           Unit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  category       String?         // raw_material, beverage, food, supplies
  subCategory    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  expenseItems   ExpenseItem[]
  inventories    Inventory[]
  stockMovements StockMovement[]
  recipeItems    RecipeItem[]

  @@index([name])
  @@index([sku])
  @@index([category])
  @@index([isActive])
  @@index([unitId])
}

model ExpenseItem {
  id            String   @id @default(cuid())
  expenseId     String
  expense       Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName   String
  quantity      Float    @default(1)
  unitId        String?
  unit          Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  unitPrice     Float
  totalPrice    Float
  currency      String   @default("USD") // USD or KHR
  paymentStatus String   @default("UNPAID") // PAID or UNPAID
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([expenseId])
  @@index([productId])
  @@index([unitId])
  @@index([currency])
  @@index([paymentStatus])
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  phone         String        @unique
  email         String?
  birthday      DateTime?
  address       String?
  notes         String?
  totalOrders   Int           @default(0)
  totalSpent    Float         @default(0)
  loyaltyPoints Int           @default(0)
  isVip         Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  orders        Order[]
  reservations  Reservation[]

  @@index([phone])
  @@index([email])
  @@index([totalSpent])
  @@index([isVip])
}

model Reservation {
  id            String    @id @default(cuid())
  tableId       String
  table         Table     @relation(fields: [tableId], references: [id], onDelete: Restrict)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String
  customerPhone String
  guestCount    Int
  reservedDate  DateTime
  reservedTime  String   // HH:MM format
  duration      Int      @default(120) // minutes
  status        String   @default("pending") // pending, confirmed, seated, cancelled, no_show
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?

  @@index([tableId])
  @@index([customerId])
  @@index([reservedDate])
  @@index([status])
  @@index([customerPhone])
}

model OrderStatusHistory {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  String
  toStatus    String
  changedBy   String?  // user ID
  notes       String?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model KitchenOrder {
  id          String    @id @default(cuid())
  orderItemId String    @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  priority    Int       @default(0) // 1=urgent, 2=high, 3=normal
  station     String?   // grill, fryer, salad, drinks, dessert
  startedAt   DateTime?
  completedAt DateTime?
  assignedTo  String?   // chef user ID
  createdAt   DateTime  @default(now())

  @@index([priority])
  @@index([station])
  @@index([assignedTo])
  @@index([startedAt])
}

model Payment {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount      Float
  currency    String   @default("USD") // USD, KHR
  method      String   // cash, card, bank_transfer, mobile_payment
  status      String   @default("completed") // pending, completed, failed, refunded
  reference   String?  // transaction ID, receipt number
  cardLast4   String?  // last 4 digits of card
  notes       String?
  processedBy String?  // user ID
  createdAt   DateTime @default(now())
  refundedAt  DateTime?

  @@index([orderId])
  @@index([status])
  @@index([method])
  @@index([createdAt])
}

model Inventory {
  id              String    @id @default(cuid())
  productId       String    @unique
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  currentStock    Float     @default(0)
  minStockLevel   Float     @default(0) // alert threshold
  maxStockLevel   Float?
  unitId          String
  unit            Unit      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  averageCost     Float     @default(0)
  lastRestocked   DateTime?
  lastStockCheck  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([productId])
  @@index([currentStock])
  @@index([minStockLevel])
}

model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        String   // IN, OUT, ADJUSTMENT, WASTE, RETURN
  quantity    Float
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)
  unitCost    Float?
  totalCost   Float?
  reason      String?
  reference   String?  // links to Order, Expense, etc.
  notes       String?
  performedBy String?  // user ID
  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@index([performedBy])
}

model RecipeItem {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Float    // amount needed per menu item
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([menuItemId, productId])
  @@index([menuItemId])
  @@index([productId])
}

model Supplier {
  id          String    @id @default(cuid())
  name        String    @unique
  contactName String?
  phone       String?
  email       String?
  address     String?
  taxId       String?
  category    String?   // food, beverage, equipment, etc.
  paymentTerms String?  // net 30, net 60, COD, etc.
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expenses    Expense[]

  @@index([name])
  @@index([category])
  @@index([isActive])
}

model Shift {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftDate    DateTime
  clockIn      DateTime
  clockOut     DateTime?
  breakMinutes Int           @default(0)
  totalHours   Float?
  status       String        @default("ongoing") // ongoing, completed, missed
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     CashSession[]

  @@index([userId])
  @@index([shiftDate])
  @@index([status])
}

model CashSession {
  id              String   @id @default(cuid())
  shiftId         String?
  shift           Shift?   @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  userId          String
  sessionNumber   String   @unique
  openingBalance  Float
  closingBalance  Float?
  expectedBalance Float?
  variance        Float?   // difference between expected and actual
  totalSales      Float    @default(0)
  totalRefunds    Float    @default(0)
  totalExpenses   Float    @default(0)
  status          String   @default("open") // open, closed, reconciled
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  notes           String?

  @@index([userId])
  @@index([status])
  @@index([openedAt])
}

model Promotion {
  id            String   @id @default(cuid())
  name          String
  description   String?
  code          String?  @unique
  type          String   // percentage, fixed_amount, buy_x_get_y, happy_hour
  value         Float    // discount value
  minOrderAmount Float?
  maxDiscount   Float?
  startDate     DateTime
  endDate       DateTime
  startTime     String?  // for happy hour: "17:00"
  endTime       String?  // for happy hour: "19:00"
  applicableDays String? // JSON: ["monday", "tuesday"]
  isActive      Boolean  @default(true)
  usageLimit    Int?     // total uses allowed
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
}

model Settings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   // stored as string, parse based on type
  type        String   // string, number, boolean, json
  category    String   // general, payment, tax, notifications, etc.
  description String?
  isPublic    Boolean  @default(false) // can be read by non-admin users
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([category])
  @@index([key])
}

model ExchangeRate {
  id          String   @id @default(cuid())
  fromCurrency String  // USD
  toCurrency   String  // KHR
  rate         Float   // 1 USD = 4100 KHR
  effectiveDate DateTime @default(now())
  source       String? // manual, api, bank
  createdAt    DateTime @default(now())
  createdBy    String?

  @@index([fromCurrency, toCurrency])
  @@index([effectiveDate])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String?  // null = system-wide notification
  type        String   // low_stock, new_order, reservation, payment_due
  title       String
  message     String
  priority    String   @default("normal") // low, normal, high, urgent
  isRead      Boolean  @default(false)
  actionUrl   String?  // link to relevant page
  createdAt   DateTime @default(now())
  readAt      DateTime?

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entity      String   // Order, MenuItem, User, etc.
  entityId    String?
  oldValue    String?  // JSON
  newValue    String?  // JSON
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}

model DailySummary {
  id              String   @id @default(cuid())
  date            DateTime @unique
  totalOrders     Int      @default(0)
  totalRevenue    Float    @default(0)
  totalExpenses   Float    @default(0)
  netProfit       Float    @default(0)
  avgOrderValue   Float    @default(0)
  topMenuItem     String?
  topCategory     String?
  currency        String   @default("USD")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
}