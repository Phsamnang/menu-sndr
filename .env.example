# Database Configuration
# Required: Database connection string for Prisma
# Example: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# NextAuth Configuration
# Required: Secret key for NextAuth session encryption
# Generate a secure random string for production (e.g., openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-key-change-in-production

# Required: Base URL of your application
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# JWT Configuration
# Optional: Secret key for JWT token generation (defaults to "your-secret-key-change-in-production")
# Should be a strong random string in production
JWT_SECRET=your-secret-key-change-in-production

# Optional: JWT token expiration time (defaults to "7d")
# Examples: "1h", "7d", "30d"
JWT_EXPIRES_IN=7d

# ImageKit Configuration
# Optional: ImageKit public key for image uploads and optimization
# Get this from your ImageKit dashboard
IMAGEKIT_PUBLIC_KEY=public_GUi4rT/ow9ZUWxoxtT8idACUVXo=

# Optional: ImageKit private key for server-side operations
# Get this from your ImageKit dashboard (keep this secret!)
IMAGEKIT_PRIVATE_KEY=your_private_key_here

# Optional: ImageKit URL endpoint for your account
# Get this from your ImageKit dashboard
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/4paezevxw

# API Configuration
# Optional: Base URL for API calls (used in server-side axios client)
# Leave empty for relative URLs, or set to full API URL
NEXT_PUBLIC_API_URL=

# Node Environment
# Optional: Environment mode (development, production, test)
# Usually set automatically by the deployment platform
NODE_ENV=development
